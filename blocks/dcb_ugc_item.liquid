{% comment %}
  DCB community item — a single customer photo tile with @handle overlay.
  Used by the DCB Community grid section.
{% endcomment %}

{% assign s = block.settings %}
{% capture inner %}
  <div class="dcb-ugc__media">
    {%- if s.image != blank -%}
      {{
        s.image
        | image_url: width: 800
        | image_tag:
          loading: 'lazy',
          sizes: '(max-width: 749px) 50vw, 20vw',
          widths: '200, 300, 400, 600, 800',
          class: 'dcb-ugc__img',
          alt: s.image.alt | default: s.handle
      }}
    {%- else -%}
      {{ 'image' | placeholder_svg_tag: 'dcb-ugc__img dcb-ugc__img--placeholder' }}
    {%- endif -%}
    {%- if s.handle != blank -%}
      <span class="dcb-ugc__handle">{{ s.handle }}</span>
    {%- endif -%}
  </div>
{% endcapture %}

<div class="dcb-ugc__item" {{ block.shopify_attributes }}>
  {%- if s.link != blank -%}
    <a class="dcb-ugc__tile" href="{{ s.link }}" target="_blank" rel="noopener" aria-label="{{ s.handle | default: 'View post' }}">
      {{ inner }}
    </a>
  {%- else -%}
    <div class="dcb-ugc__tile">{{ inner }}</div>
  {%- endif -%}
</div>

{% stylesheet %}
  .dcb-ugc__tile {
    display: block;
    position: relative;
    overflow: hidden;
    border-radius: var(--style-border-radius-card, 2px);
    color: var(--color-foreground);
  }

  .dcb-ugc__media {
    position: relative;
    aspect-ratio: 1 / 1;
  }

  .dcb-ugc__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .dcb-ugc__img--placeholder {
    background: var(--color-border);
  }

  .dcb-ugc__handle {
    position: absolute;
    inset-inline: 0;
    inset-block-end: 0;
    padding: 18px 12px 10px;
    font-family: var(--font-subheading--family, var(--font-body--family));
    font-size: var(--font-size--xs);
    letter-spacing: 0.04em;
    color: #fff;
    background: linear-gradient(to top, rgb(0 0 0 / 0.7), transparent);
    opacity: 0;
    transform: translateY(6px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  @media (hover: hover) {
    .dcb-ugc__tile:hover .dcb-ugc__img { transform: scale(1.06); }
    .dcb-ugc__tile:hover .dcb-ugc__handle { opacity: 1; transform: none; }
  }

  /* Touch devices: keep the handle visible since there's no hover */
  @media (hover: none) {
    .dcb-ugc__handle { opacity: 1; transform: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .dcb-ugc__img { transition: none; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Community photo",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "Image" },
    { "type": "text", "id": "handle", "label": "Handle / caption", "default": "@dcbworldwide" },
    { "type": "url", "id": "link", "label": "Link (e.g. IG post)" }
  ]
}
{% endschema %}
