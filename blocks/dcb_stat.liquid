{% comment %}
  DCB stat — a single animated count-up figure. Used by the DCB Stats section.
{% endcomment %}

{% assign s = block.settings %}

<dcb-countup
  class="dcb-stat"
  data-target="{{ s.target }}"
  data-decimals="{{ s.decimals }}"
  data-duration="1600"
  {{ block.shopify_attributes }}
>
  <span class="dcb-stat__figure">
    {%- if s.prefix != blank -%}<span class="dcb-stat__affix">{{ s.prefix }}</span>{%- endif -%}
    <span class="dcb-stat__num" data-countup>0</span>
    {%- if s.suffix != blank -%}<span class="dcb-stat__affix">{{ s.suffix }}</span>{%- endif -%}
  </span>
  {%- if s.label != blank -%}
    <span class="dcb-stat__label">{{ s.label }}</span>
  {%- endif -%}
</dcb-countup>

{% stylesheet %}
  .dcb-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 6px;
    padding: 20px 12px;
  }

  .dcb-stat__figure {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight, 700);
    line-height: 1;
    font-size: clamp(2.5rem, 9vw, 4.5rem);
    color: var(--color-foreground-heading);
    display: inline-flex;
    align-items: baseline;
  }

  .dcb-stat__affix { font-size: 0.6em; }

  .dcb-stat__num { font-variant-numeric: tabular-nums; }

  .dcb-stat__label {
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: var(--font-size--xs);
    color: rgb(var(--color-foreground-rgb) / 0.7);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Stat",
  "settings": [
    { "type": "number", "id": "target", "label": "Target number", "default": 100 },
    { "type": "text", "id": "prefix", "label": "Prefix", "default": "" },
    { "type": "text", "id": "suffix", "label": "Suffix", "default": "+" },
    { "type": "range", "id": "decimals", "label": "Decimal places", "min": 0, "max": 2, "step": 1, "default": 0 },
    { "type": "text", "id": "label", "label": "Label", "default": "Happy customers" }
  ]
}
{% endschema %}
