{% doc %}
  @prompt
    create me a section for my location of my store a map 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-store-location-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-store-location-container-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.content_gap }}px;
    align-items: stretch;
  }

  .ai-store-location-info-{{ ai_gen_id }} {
    flex: 1;
    padding: {{ block.settings.content_padding }}px;
    background-color: {{ block.settings.info_background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .ai-store-location-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0;
  }

  .ai-store-location-details-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-store-location-detail-{{ ai_gen_id }} {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  .ai-store-location-icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    color: {{ block.settings.icon_color }};
    margin-top: 2px;
  }

  .ai-store-location-text-{{ ai_gen_id }} {
    flex: 1;
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.5;
  }

  .ai-store-location-text-{{ ai_gen_id }} a {
    color: {{ block.settings.link_color }};
    text-decoration: none;
  }

  .ai-store-location-text-{{ ai_gen_id }} a:hover {
    text-decoration: underline;
  }

  .ai-store-location-map-{{ ai_gen_id }} {
    flex: 1;
    min-height: 400px;
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    position: relative;
  }

  .ai-store-location-map-{{ ai_gen_id }} iframe {
    width: 100%;
    height: 100%;
    border: 0;
    position: absolute;
    top: 0;
    left: 0;
  }

  .ai-store-location-map-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-store-location-map-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-store-location-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-store-location-container-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-store-location-map-{{ ai_gen_id }} {
      min-height: 300px;
    }
  }
{% endstyle %}

<store-location-{{ ai_gen_id }}
  class="ai-store-location-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-store-location-container-{{ ai_gen_id }}">
    <div class="ai-store-location-info-{{ ai_gen_id }}">
      {% if block.settings.heading != blank %}
        <h2 class="ai-store-location-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}

      <div class="ai-store-location-details-{{ ai_gen_id }}">
        {% if block.settings.address != blank %}
          <div class="ai-store-location-detail-{{ ai_gen_id }}">
            <div class="ai-store-location-icon-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
            </div>
            <div class="ai-store-location-text-{{ ai_gen_id }}">{{ block.settings.address }}</div>
          </div>
        {% endif %}

        {% if block.settings.phone != blank %}
          <div class="ai-store-location-detail-{{ ai_gen_id }}">
            <div class="ai-store-location-icon-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path>
              </svg>
            </div>
            <div class="ai-store-location-text-{{ ai_gen_id }}">
              <a href="tel:{{ block.settings.phone }}">{{ block.settings.phone }}</a>
            </div>
          </div>
        {% endif %}

        {% if block.settings.email != blank %}
          <div class="ai-store-location-detail-{{ ai_gen_id }}">
            <div class="ai-store-location-icon-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path>
                <polyline points="22,6 12,13 2,6"></polyline>
              </svg>
            </div>
            <div class="ai-store-location-text-{{ ai_gen_id }}">
              <a href="mailto:{{ block.settings.email }}">{{ block.settings.email }}</a>
            </div>
          </div>
        {% endif %}

        {% if block.settings.hours != blank %}
          <div class="ai-store-location-detail-{{ ai_gen_id }}">
            <div class="ai-store-location-icon-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle>
                <polyline points="12 6 12 12 16 14"></polyline>
              </svg>
            </div>
            <div class="ai-store-location-text-{{ ai_gen_id }}">{{ block.settings.hours }}</div>
          </div>
        {% endif %}
      </div>
    </div>

    <div class="ai-store-location-map-{{ ai_gen_id }}">
      {% if block.settings.map_embed_url != blank %}
        <iframe
          src="{{ block.settings.map_embed_url }}"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      {% else %}
        <div class="ai-store-location-map-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-store-location-empty-state-{{ ai_gen_id }}">
            Next, add your Google Maps embed URL
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</store-location-{{ ai_gen_id }}>

<script>
  (function() {
    class StoreLocation{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('store-location-{{ ai_gen_id }}', StoreLocation{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Store location",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Store information"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Visit our store"
    },
    {
      "type": "textarea",
      "id": "address",
      "label": "Address",
      "default": "123 Main Street, City, State 12345"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone number",
      "default": "+1 (555) 123-4567"
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email"
    },
    {
      "type": "textarea",
      "id": "hours",
      "label": "Store hours",
      "default": "Monday - Friday: 9:00 AM - 6:00 PM\nSaturday: 10:00 AM - 4:00 PM\nSunday: Closed"
    },
    {
      "type": "header",
      "content": "Map"
    },
    {
      "type": "text",
      "id": "map_embed_url",
      "label": "Google Maps embed URL",
      "info": "Get the embed URL from Google Maps by clicking Share > Embed a map"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "content_gap",
      "label": "Gap between sections",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "content_padding",
      "label": "Info section padding",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "info_background_color",
      "label": "Info background",
      "default": "#f4f4f4"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading",
      "default": "#030302"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#030302"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icons",
      "default": "#030302"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Links",
      "default": "#030302"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    }
  ],
  "presets": [
    {
      "name": "Store location"
    }
  ]
}
{% endschema %}
