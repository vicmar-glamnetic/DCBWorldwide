{% comment %}
  DCB Stats — a row of animated count-up figures for social proof.
  Custom DCB section. Uses the dcb_stat block + dcb-countup.js.
{% endcomment %}

{% assign s = section.settings %}

<script src="{{ 'dcb-countup.js' | asset_url }}" type="module" fetchpriority="low"></script>

<div class="section-background color-{{ s.color_scheme }}"></div>
<div
  class="section section--page-width color-{{ s.color_scheme }} spacing-style dcb-stats"
  style="
    {%- render 'spacing-style', settings: section.settings %}
    --dcb-stats-cols: {{ s.columns }};
  "
  data-testid="dcb-stats"
>
  {%- if s.heading != blank -%}
    <h2 class="dcb-stats__heading">{{ s.heading }}</h2>
  {%- endif -%}
  <div class="dcb-stats__grid{% if s.show_dividers %} dcb-stats__grid--dividers{% endif %}">
    {% content_for 'blocks' %}
  </div>
</div>

{% stylesheet %}
  .dcb-stats { text-align: center; }

  .dcb-stats__heading {
    margin: 0 0 28px;
    text-transform: uppercase;
  }

  .dcb-stats__grid {
    display: grid;
    grid-template-columns: repeat(var(--dcb-stats-cols, 4), 1fr);
    gap: 24px;
  }

  .dcb-stats__grid--dividers {
    gap: 1px;
    background-color: var(--color-border);
    border: 1px solid var(--color-border);
  }

  .dcb-stats__grid--dividers .dcb-stat {
    background-color: var(--color-background);
  }

  @media screen and (max-width: 749px) {
    .dcb-stats__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "DCB Stats",
  "tag": "section",
  "class": "section-wrapper",
  "disabled_on": { "groups": ["header", "footer"] },
  "blocks": [{ "type": "dcb_stat" }],
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "BY THE NUMBERS" },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns (desktop)",
      "min": 2,
      "max": 5,
      "step": 1,
      "default": 4
    },
    { "type": "checkbox", "id": "show_dividers", "label": "Show hairline dividers", "default": true },
    { "type": "color_scheme", "id": "color_scheme", "label": "Color scheme", "default": "scheme-1" },
    { "type": "header", "content": "Padding" },
    { "type": "range", "id": "padding-block-start", "label": "Top", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 64 },
    { "type": "range", "id": "padding-block-end", "label": "Bottom", "min": 0, "max": 160, "step": 4, "unit": "px", "default": 64 }
  ],
  "presets": [
    {
      "name": "DCB Stats",
      "category": "DCB",
      "blocks": {
        "s1": { "type": "dcb_stat", "settings": { "target": 50, "suffix": "+", "label": "Drops released" } },
        "s2": { "type": "dcb_stat", "settings": { "target": 25, "suffix": "K+", "label": "Pieces shipped" } },
        "s3": { "type": "dcb_stat", "settings": { "target": 100, "suffix": "%", "label": "Authentic" } },
        "s4": { "type": "dcb_stat", "settings": { "target": 4, "suffix": ".9★", "label": "Avg. rating", "decimals": 1 } }
      },
      "block_order": ["s1", "s2", "s3", "s4"]
    }
  ]
}
{% endschema %}
