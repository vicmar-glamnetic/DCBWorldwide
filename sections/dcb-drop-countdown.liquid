{% comment %}
  DCB Drop Countdown — hype countdown to a product/collection drop, with an
  optional background image and CTA. Custom DCB section (no core fork).
  Colors inherit from the chosen color scheme; defaults to deep-black scheme-5.
  Mobile-first. Background image uses responsive srcset + lazy loading.
{% endcomment %}

{% liquid
  assign s = section.settings
  assign deadline = ''
  if s.end_date != blank
    assign t = s.end_time
    if t == blank
      assign t = '00:00'
    endif
    assign deadline = s.end_date | append: 'T' | append: t | append: ':00' | append: s.utc_offset
  endif
%}

<script src="{{ 'dcb-countdown.js' | asset_url }}" type="module" fetchpriority="low"></script>

<div class="section-background color-{{ s.color_scheme }}"></div>
<div
  class="section section--full-width color-{{ s.color_scheme }} spacing-style dcb-drop dcb-drop--align-{{ s.content_alignment }}"
  style="
    {%- render 'spacing-style', settings: section.settings %}
    --dcb-drop-min-height: {{ s.min_height }}px;
    --dcb-drop-overlay: {{ s.overlay_opacity | divided_by: 100.0 }};
  "
  data-testid="dcb-drop-countdown"
>
  {%- if s.background_image != blank -%}
    <div class="dcb-drop__media">
      {{
        s.background_image
        | image_url: width: 1800
        | image_tag:
          loading: 'lazy',
          sizes: '100vw',
          widths: '375, 550, 750, 1100, 1500, 1800',
          class: 'dcb-drop__image',
          alt: s.background_image.alt | default: s.heading
      }}
    </div>
  {%- endif -%}

  <div class="dcb-drop__inner">
    {%- if s.eyebrow != blank -%}
      <p class="dcb-drop__eyebrow">{{ s.eyebrow }}</p>
    {%- endif -%}

    {%- if s.heading != blank -%}
      <h2 class="dcb-drop__heading">{{ s.heading }}</h2>
    {%- endif -%}

    {%- if s.expired_heading != blank -%}
      <h2 class="dcb-drop__heading dcb-drop__heading--expired">{{ s.expired_heading }}</h2>
    {%- endif -%}

    {%- if s.subheading != blank -%}
      <p class="dcb-drop__subheading">{{ s.subheading }}</p>
    {%- endif -%}

    {%- if deadline != blank -%}
      <dcb-countdown
        class="dcb-drop__timer"
        data-deadline="{{ deadline }}"
        role="timer"
        aria-label="Countdown to {{ s.heading | escape }}"
      >
        <div class="dcb-drop__unit">
          <span class="dcb-drop__num" data-unit="days">00</span>
          <span class="dcb-drop__label">Days</span>
        </div>
        <span class="dcb-drop__sep" aria-hidden="true">:</span>
        <div class="dcb-drop__unit">
          <span class="dcb-drop__num" data-unit="hours">00</span>
          <span class="dcb-drop__label">Hrs</span>
        </div>
        <span class="dcb-drop__sep" aria-hidden="true">:</span>
        <div class="dcb-drop__unit">
          <span class="dcb-drop__num" data-unit="minutes">00</span>
          <span class="dcb-drop__label">Min</span>
        </div>
        <span class="dcb-drop__sep" aria-hidden="true">:</span>
        <div class="dcb-drop__unit">
          <span class="dcb-drop__num" data-unit="seconds">00</span>
          <span class="dcb-drop__label">Sec</span>
        </div>
      </dcb-countdown>
    {%- endif -%}

    {%- if s.button_label != blank and s.button_link != blank -%}
      <a class="dcb-drop__button button" href="{{ s.button_link }}">{{ s.button_label }}</a>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .dcb-drop {
    position: relative;
    display: flex;
    align-items: center;
    min-height: var(--dcb-drop-min-height, 420px);
    overflow: hidden;
    color: var(--color-foreground);
  }

  .dcb-drop__media,
  .dcb-drop__image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .dcb-drop__media::after {
    content: '';
    position: absolute;
    inset: 0;
    background: rgb(0 0 0 / var(--dcb-drop-overlay, 0.5));
  }

  .dcb-drop__inner {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: var(--page-width, 1200px);
    margin-inline: auto;
    padding-inline: var(--page-margin, 20px);
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .dcb-drop--align-center .dcb-drop__inner {
    align-items: center;
    text-align: center;
  }

  .dcb-drop--align-left .dcb-drop__inner {
    align-items: flex-start;
    text-align: left;
  }

  .dcb-drop__eyebrow {
    margin: 0;
    font-family: var(--font-subheading--family, var(--font-body--family));
    text-transform: uppercase;
    letter-spacing: 0.18em;
    font-size: var(--font-size--xs);
    color: rgb(var(--color-foreground-rgb) / 0.75);
  }

  .dcb-drop__heading {
    margin: 0;
    color: var(--color-foreground-heading);
  }

  /* Expired heading hidden until the timer flips the host */
  .dcb-drop__heading--expired {
    display: none;
  }

  .dcb-drop:has(dcb-countdown[data-expired]) .dcb-drop__heading:not(.dcb-drop__heading--expired) {
    display: none;
  }

  .dcb-drop:has(dcb-countdown[data-expired]) .dcb-drop__heading--expired {
    display: block;
  }

  .dcb-drop:has(dcb-countdown[data-expired]) .dcb-drop__timer {
    opacity: 0.35;
  }

  .dcb-drop__subheading {
    margin: 0;
    max-width: 52ch;
    color: rgb(var(--color-foreground-rgb) / 0.85);
  }

  .dcb-drop__timer {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin-block: 8px;
  }

  .dcb-drop__unit {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 56px;
  }

  .dcb-drop__num {
    font-family: var(--font-heading--family);
    font-weight: 700;
    font-variant-numeric: tabular-nums;
    font-size: clamp(2.25rem, 9vw, 4rem);
    line-height: 1;
    color: var(--color-foreground-heading);
  }

  .dcb-drop__label {
    margin-top: 6px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: var(--font-size--2xs);
    color: rgb(var(--color-foreground-rgb) / 0.7);
  }

  .dcb-drop__sep {
    font-size: clamp(1.75rem, 7vw, 3rem);
    line-height: 1;
    color: rgb(var(--color-foreground-rgb) / 0.4);
    padding-top: 2px;
  }

  .dcb-drop__button {
    margin-top: 8px;
  }

  @media screen and (max-width: 480px) {
    .dcb-drop__unit { min-width: 44px; }
    .dcb-drop__sep { display: none; }
    .dcb-drop__timer { gap: 14px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "DCB Drop countdown",
  "tag": "section",
  "class": "section-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "NEXT DROP"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "THE DROP IS COMING"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Set your alarm. Limited stock, no restocks."
    },
    {
      "type": "header",
      "content": "Countdown target"
    },
    {
      "type": "text",
      "id": "end_date",
      "label": "End date (YYYY-MM-DD)",
      "info": "Example: 2026-07-01",
      "default": "2026-07-01"
    },
    {
      "type": "text",
      "id": "end_time",
      "label": "End time (HH:MM, 24h)",
      "info": "Example: 18:00",
      "default": "18:00"
    },
    {
      "type": "select",
      "id": "utc_offset",
      "label": "Timezone offset",
      "default": "+08:00",
      "options": [
        { "value": "+08:00", "label": "Philippines (UTC+8)" },
        { "value": "+00:00", "label": "UTC" },
        { "value": "-05:00", "label": "US Eastern (UTC-5)" },
        { "value": "-08:00", "label": "US Pacific (UTC-8)" },
        { "value": "+09:00", "label": "Japan/Korea (UTC+9)" },
        { "value": "+10:00", "label": "Sydney (UTC+10)" }
      ]
    },
    {
      "type": "text",
      "id": "expired_heading",
      "label": "Heading after countdown ends",
      "default": "IT'S LIVE"
    },
    {
      "type": "header",
      "content": "Call to action"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop the drop"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Image overlay",
      "min": 0,
      "max": 90,
      "step": 5,
      "unit": "%",
      "default": 50
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ]
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-5"
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Minimum height",
      "min": 240,
      "max": 720,
      "step": 20,
      "unit": "px",
      "default": 420
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "Top",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "Bottom",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "DCB Drop countdown",
      "category": "DCB"
    }
  ]
}
{% endschema %}
